<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enquete com Cadastro - Pesquisa de Satisfação</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: #333;
        }

        .container {
            width: 100%;
            max-width: 900px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 50px 40px;
            text-align: center;
        }

        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .header p {
            font-size: 1.1em;
            opacity: 0.95;
            line-height: 1.6;
        }

        .content {
            padding: 50px 40px;
        }

        .form-section {
            margin-bottom: 40px;
        }

        .form-section:last-child {
            margin-bottom: 0;
        }

        .section-title {
            font-size: 1.4em;
            color: #667eea;
            margin-bottom: 25px;
            font-weight: 600;
            padding-bottom: 12px;
            border-bottom: 2px solid #f0f0f0;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
            font-size: 0.95em;
        }

        .required {
            color: #e74c3c;
        }

        input[type="text"],
        input[type="email"],
        input[type="tel"],
        input[type="date"],
        select,
        textarea {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 1em;
            font-family: inherit;
            transition: all 0.3s ease;
            background: #f9f9f9;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="tel"]:focus,
        input[type="date"]:focus,
        select:focus,
        textarea:focus {
            outline: none;
            border-color: #667eea;
            background: white;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        textarea {
            resize: vertical;
            min-height: 100px;
            font-family: inherit;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-row.full {
            grid-template-columns: 1fr;
        }

        /* Perguntas da Enquete */
        .question-group {
            margin-bottom: 30px;
            padding: 20px;
            background: #f9f9f9;
            border-radius: 12px;
            border-left: 4px solid #667eea;
        }

        .question-title {
            font-weight: 600;
            color: #333;
            margin-bottom: 15px;
            font-size: 1em;
        }

        .radio-group,
        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .radio-option,
        .checkbox-option {
            display: flex;
            align-items: center;
            padding: 10px 12px;
            background: white;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .radio-option:hover,
        .checkbox-option:hover {
            border-color: #667eea;
            background: #f9f9f9;
        }

        .radio-option input[type="radio"],
        .checkbox-option input[type="checkbox"] {
            margin-right: 12px;
            cursor: pointer;
            width: 18px;
            height: 18px;
            accent-color: #667eea;
        }

        .radio-option label,
        .checkbox-option label {
            margin: 0;
            cursor: pointer;
            font-weight: 400;
            flex: 1;
        }

        /* Checkbox de Políticas */
        .policy-checkbox {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 15px;
            background: #f0f4ff;
            border: 1.5px solid #667eea;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .policy-checkbox input[type="checkbox"] {
            margin-top: 3px;
            width: 20px;
            height: 20px;
            min-width: 20px;
            cursor: pointer;
            accent-color: #667eea;
        }

        .policy-checkbox label {
            margin: 0;
            cursor: pointer;
            font-weight: 400;
            font-size: 0.95em;
            line-height: 1.5;
        }

        .policy-checkbox a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .policy-checkbox a:hover {
            color: #764ba2;
            text-decoration: underline;
        }

        /* Botões */
        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 40px;
        }

        button {
            flex: 1;
            padding: 14px 30px;
            border: none;
            border-radius: 8px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-submit {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-reset {
            background: #e0e0e0;
            color: #333;
        }

        .btn-reset:hover {
            background: #d0d0d0;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            animation: fadeIn 0.3s ease;
        }

        .modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: white;
            border-radius: 15px;
            max-width: 600px;
            max-height: 80vh;
            overflow-y: auto;
            padding: 40px;
            position: relative;
            animation: slideUp 0.4s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            background: #f0f0f0;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-size: 24px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            color: #333;
        }

        .modal-close:hover {
            background: #e0e0e0;
            transform: rotate(90deg);
        }

        .modal-content h2 {
            color: #667eea;
            font-size: 1.8em;
            margin-bottom: 20px;
        }

        .modal-content h3 {
            color: #764ba2;
            font-size: 1.2em;
            margin-top: 25px;
            margin-bottom: 12px;
        }

        .modal-content p {
            color: #666;
            line-height: 1.8;
            margin-bottom: 15px;
            font-size: 0.95em;
        }

        .modal-content ul {
            margin-left: 25px;
            margin-bottom: 15px;
        }

        .modal-content li {
            color: #666;
            line-height: 1.8;
            margin-bottom: 8px;
            font-size: 0.95em;
        }

        .highlight-box {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
        }

        .highlight-box strong {
            color: #856404;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        @keyframes slideUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .success-message {
            display: none;
            background: #d4edda;
            color: #155724;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #c3e6cb;
        }

        .success-message.show {
            display: block;
            animation: slideUp 0.4s ease;
        }

        .error-message {
            display: none;
            background: #f8d7da;
            color: #721c24;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #f5c6cb;
        }

        .error-message.show {
            display: block;
            animation: slideUp 0.4s ease;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header {
                padding: 40px 25px;
            }

            .header h1 {
                font-size: 1.8em;
            }

            .content {
                padding: 30px 25px;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .form-actions {
                flex-direction: column;
            }

            .modal-content {
                margin: 20px;
                padding: 30px 20px;
            }

            .section-title {
                font-size: 1.2em;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>📋 Enquete com Cadastro</h1>
        <p>Sua opinião é importante! Ajude-nos a melhorar respondendo esta breve pesquisa de satisfação.</p>
    </div>

    <div class="content">
        <div class="success-message" id="successMessage">
            ✓ Obrigado! Sua resposta foi registrada com sucesso.
        </div>

        <div class="error-message" id="errorMessage"></div>

        <form id="enqueteForm">
            <!-- SEÇÃO 1: DADOS PESSOAIS -->
            <div class="form-section">
                <h2 class="section-title">1. Seus Dados Pessoais</h2>

                <div class="form-row">
                    <div class="form-group">
                        <label for="nome">Nome Completo <span class="required">*</span></label>
                        <input type="text" id="nome" name="nome" placeholder="Seu nome completo" required>
                    </div>
                    <div class="form-group">
                        <label for="email">E-mail <span class="required">*</span></label>
                        <input type="email" id="email" name="email" placeholder="seu@email.com" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="telefone">Telefone (Opcional)</label>
                        <input type="tel" id="telefone" name="telefone" placeholder="(XX) XXXXX-XXXX">
                    </div>
                    <div class="form-group">
                        <label for="idade">Faixa Etária <span class="required">*</span></label>
                        <select id="idade" name="idade" required>
                            <option value="">Selecione uma opção</option>
                            <option value="18-25">18 a 25 anos</option>
                            <option value="26-35">26 a 35 anos</option>
                            <option value="36-50">36 a 50 anos</option>
                            <option value="51-60">51 a 60 anos</option>
                            <option value="61+">61+ anos</option>
                        </select>
                    </div>
                </div>

                <div class="form-row full">
                    <div class="form-group">
                        <label for="cidade">Cidade <span class="required">*</span></label>
                        <input type="text" id="cidade" name="cidade" placeholder="Sua cidade" required>
                    </div>
                </div>
            </div>

            <!-- SEÇÃO 2: PERGUNTAS DA ENQUETE -->
            <div class="form-section">
                <h2 class="section-title">2. Suas Opiniões</h2>

                <!-- Pergunta 1 -->
                <div class="question-group">
                    <div class="question-title">Como você avalia nosso serviço/produto? <span class="required">*</span></div>
                    <div class="radio-group">
                        <div class="radio-option">
                            <input type="radio" id="q1_1" name="pergunta1" value="excelente" required>
                            <label for="q1_1">Excelente</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q1_2" name="pergunta1" value="bom">
                            <label for="q1_2">Bom</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q1_3" name="pergunta1" value="regular">
                            <label for="q1_3">Regular</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q1_4" name="pergunta1" value="ruim">
                            <label for="q1_4">Ruim</label>
                        </div>
                    </div>
                </div>

                <!-- Pergunta 2 -->
                <div class="question-group">
                    <div class="question-title">Qual aspecto você mais gostou? <span class="required">*</span></div>
                    <div class="radio-group">
                        <div class="radio-option">
                            <input type="radio" id="q2_1" name="pergunta2" value="qualidade" required>
                            <label for="q2_1">Qualidade</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q2_2" name="pergunta2" value="preco">
                            <label for="q2_2">Preço</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q2_3" name="pergunta2" value="atendimento">
                            <label for="q2_3">Atendimento</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q2_4" name="pergunta2" value="variedade">
                            <label for="q2_4">Variedade</label>
                        </div>
                    </div>
                </div>

                <!-- Pergunta 3 -->
                <div class="question-group">
                    <div class="question-title">Você recomendaria para um amigo? <span class="required">*</span></div>
                    <div class="radio-group">
                        <div class="radio-option">
                            <input type="radio" id="q3_1" name="pergunta3" value="sim_com_certeza" required>
                            <label for="q3_1">Sim, com certeza</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q3_2" name="pergunta3" value="provavelmente">
                            <label for="q3_2">Provavelmente</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q3_3" name="pergunta3" value="talvez">
                            <label for="q3_3">Talvez</label>
                        </div>
                        <div class="radio-option">
                            <input type="radio" id="q3_4" name="pergunta3" value="nao">
                            <label for="q3_4">Não</label>
                        </div>
                    </div>
                </div>

                <!-- Pergunta 4 -->
                <div class="question-group">
                    <div class="question-title">Quais áreas você acha que precisam melhorar? (Selecione quantas desejar)</div>
                    <div class="checkbox-group">
                        <div class="checkbox-option">
                            <input type="checkbox" id="q4_1" name="pergunta4" value="qualidade">
                            <label for="q4_1">Qualidade do Produto/Serviço</label>
                        </div>
                        <div class="checkbox-option">
                            <input type="checkbox" id="q4_2" name="pergunta4" value="preco">
                            <label for="q4_2">Preço</label>
                        </div>
                        <div class="checkbox-option">
                            <input type="checkbox" id="q4_3" name="pergunta4" value="atendimento">
                            <label for="q4_3">Atendimento ao Cliente</label>
                        </div>
                        <div class="checkbox-option">
                            <input type="checkbox" id="q4_4" name="pergunta4" value="entrega">
                            <label for="q4_4">Entrega/Disponibilidade</label>
                        </div>
                        <div class="checkbox-option">
                            <input type="checkbox" id="q4_5" name="pergunta4" value="website">
                            <label for="q4_5">Website/App</label>
                        </div>
                    </div>
                </div>

                <!-- Pergunta 5 -->
                <div class="question-group">
                    <div class="question-title">Algum comentário ou sugestão? (Opcional)</div>
                    <textarea id="comentario" name="comentario" placeholder="Compartilhe suas ideias e sugestões..."></textarea>
                </div>
            </div>

            <!-- SEÇÃO 3: POLÍTICAS E CONSENTIMENTO -->
            <div class="form-section">
                <h2 class="section-title">3. Consentimento e Políticas</h2>

                <div class="policy-checkbox">
                    <input type="checkbox" id="privacidade" name="privacidade" required>
                    <label for="privacidade">Concordo com a <a href="#" onclick="openModal('privacidade'); return false;">Política de Privacidade</a> <span class="required">*</span></label>
                </div>

                <div class="policy-checkbox">
                    <input type="checkbox" id="termos" name="termos" required>
                    <label for="termos">Concordo com os <a href="#" onclick="openModal('termos'); return false;">Termos de Serviço</a> <span class="required">*</span></label>
                </div>

                <div class="policy-checkbox">
                    <input type="checkbox" id="newsletter" name="newsletter">
                    <label for="newsletter">Desejo receber notícias e promoções por e-mail</label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">Enviar Enquete</button>
                    <button type="reset" class="btn-reset">Limpar Formulário</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- MODAL PRIVACIDADE -->
<div id="modalPrivacidade" class="modal">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('privacidade')">&times;</button>
        <h2>Política de Privacidade</h2>

        <h3>1. Coleta de Dados</h3>
        <p>Coletamos informações que você nos fornece diretamente através do formulário de enquete, incluindo nome, e-mail, telefone, cidade e respostas às perguntas da pesquisa.</p>

        <h3>2. Uso de Dados</h3>
        <p>Utilizamos seus dados para:</p>
        <ul>
            <li>Analisar as respostas da enquete e melhorar nossos serviços</li>
            <li>Enviar notícias e atualizações (se consentido)</li>
            <li>Cumprir obrigações legais e regulatórias</li>
            <li>Melhorar a experiência do usuário</li>
        </ul>

        <h3>3. Segurança de Dados</h3>
        <p>Implementamos medidas de segurança técnicas e administrativas para proteger suas informações pessoais contra acesso não autorizado, alteração ou destruição.</p>

        <h3>4. Compartilhamento de Dados</h3>
        <p>Nunca compartilharemos suas informações pessoais com terceiros sem seu consentimento explícito, exceto quando exigido por lei.</p>

        <h3>5. Retenção de Dados</h3>
        <p>Mantemos seus dados pelo tempo necessário para cumprir os objetivos da enquete e nossas obrigações legais. Você pode solicitar a exclusão de seus dados a qualquer momento.</p>

        <h3>6. Seus Direitos</h3>
        <p>Você tem o direito de:</p>
        <ul>
            <li>Acessar seus dados pessoais</li>
            <li>Corrigir dados imprecisos</li>
            <li>Solicitar a exclusão de seus dados</li>
            <li>Optar por não receber comunicações de marketing</li>
        </ul>

        <h3>7. Cookies</h3>
        <p>Nosso site pode usar cookies para melhorar sua experiência. Você pode controlar as configurações de cookies em seu navegador.</p>

        <h3>8. Contato</h3>
        <p>Para questões sobre privacidade, entre em contato conosco em: <strong>privacidade@empresa.com</strong></p>

        <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0; font-size: 0.9em; color: #999;">
            <strong>Última atualização:</strong> 15 de março de 2026
        </p>
    </div>
</div>

<!-- MODAL TERMOS -->
<div id="modalTermos" class="modal">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('termos')">&times;</button>
        <h2>Termos de Serviço</h2>

        <h3>1. Aceitação dos Termos</h3>
        <p>Ao participar desta enquete, você concorda em estar vinculado por estes Termos de Serviço.</p>

        <h3>2. Uso Aceitável</h3>
        <p>Você concorda em usar esta enquete apenas para fins legítimos e de forma que não infrinja os direitos de terceiros ou viole qualquer lei aplicável.</p>

        <h3>3. Propriedade Intelectual</h3>
        <p>Todo o conteúdo desta enquete, incluindo textos, gráficos e design, é propriedade nossa e é protegido por leis de direitos autorais internacionais.</p>

        <h3>4. Isenção de Responsabilidade</h3>
        <p>Esta enquete é fornecida "como está" sem garantias de qualquer tipo. Não garantimos que será ininterrupta ou livre de erros.</p>

        <h3>5. Limitação de Responsabilidade</h3>
        <p>Não seremos responsáveis por danos diretos, indiretos, incidentais ou consequentes resultantes do seu uso ou incapacidade de usar esta enquete.</p>

        <h3>6. Modificações dos Termos</h3>
        <p>Reservamos o direito de modificar estes termos a qualquer momento. Seu uso contínuo da enquete após tais modificações constitui sua aceitação dos novos termos.</p>

        <h3>7. Rescisão</h3>
        <p>Podemos rescindir ou suspender seu acesso a qualquer momento, por qualquer motivo, sem aviso prévio.</p>

        <h3>8. Lei Aplicável</h3>
        <p>Estes termos são regidos pelas leis aplicáveis em sua jurisdição.</p>

        <h3>9. Contato</h3>
        <p>Para questões sobre estes termos, entre em contato conosco em: <strong>termos@empresa.com</strong></p>

        <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #e0e0e0; font-size: 0.9em; color: #999;">
            <strong>Última atualização:</strong> 15 de março de 2026
        </p>
    </div>
</div>

<script>
    // Função para abrir modal
    function openModal(type) {
        const modal = document.getElementById('modal' + capitalizeFirst(type));
        if (modal) {
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    }

    // Função para fechar modal
    function closeModal(type) {
        const modal = document.getElementById('modal' + capitalizeFirst(type));
        if (modal) {
            modal.classList.remove('active');
            document.body.style.overflow = 'auto';
        }
    }

    // Função auxiliar para capitalizar primeira letra
    function capitalizeFirst(str) {
        return str.charAt(0).toUpperCase() + str.slice(1);
    }

    // Fechar modal ao clicar fora do conteúdo
    document.querySelectorAll('.modal').forEach(modal => {
        modal.addEventListener('click', function(e) {
            if (e.target === this) {
                this.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        });
    });

    // Fechar modais com tecla ESC
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            document.querySelectorAll('.modal.active').forEach(modal => {
                modal.classList.remove('active');
                document.body.style.overflow = 'auto';
            });
        }
    });

    // Validação e envio do formulário
    document.getElementById('enqueteForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const errorMessage = document.getElementById('errorMessage');
        const successMessage = document.getElementById('successMessage');

        // Limpar mensagens anteriores
        errorMessage.classList.remove('show');
        successMessage.classList.remove('show');

        // Validar checkboxes obrigatórios
        const privacidade = document.getElementById('privacidade').checked;
        const termos = document.getElementById('termos').checked;

        if (!privacidade || !termos) {
            errorMessage.textContent = '⚠ Você deve aceitar a Política de Privacidade e os Termos de Serviço!';
            errorMessage.classList.add('show');
            return;
        }

        // Validar que as perguntas obrigatórias foram respondidas
        const pergunta1 = document.querySelector('input[name="pergunta1"]:checked');
        const pergunta2 = document.querySelector('input[name="pergunta2"]:checked');
        const pergunta3 = document.querySelector('input[name="pergunta3"]:checked');

        if (!pergunta1 || !pergunta2 || !pergunta3) {
            errorMessage.textContent = '⚠ Por favor, responda todas as perguntas obrigatórias!';
            errorMessage.classList.add('show');
            return;
        }

        // Coletar dados do formulário
        const formData = new FormData(this);
        const data = {
            nome: formData.get('nome'),
            email: formData.get('email'),
            telefone: formData.get('telefone'),
            idade: formData.get('idade'),
            cidade: formData.get('cidade'),
            pergunta1: formData.get('pergunta1'),
            pergunta2: formData.get('pergunta2'),
            pergunta3: formData.get('pergunta3'),
            pergunta4: formData.getAll('pergunta4'),
            comentario: formData.get('comentario'),
            newsletter: formData.get('newsletter') ? 'sim' : 'não',
            dataEnvio: new Date().toLocaleString('pt-BR')
        };

        // Aqui você poderia enviar os dados para um servidor
        console.log('Dados da enquete:', data);

        // Salvar no localStorage como exemplo
        let enquetes = JSON.parse(localStorage.getItem('enquetes')) || [];
        enquetes.push(data);
        localStorage.setItem('enquetes', JSON.stringify(enquetes));

        // Mostrar mensagem de sucesso
        successMessage.classList.add('show');

        // Limpar formulário
        this.reset();

        // Scroll para o topo
        window.scrollTo({ top: 0, behavior: 'smooth' });

        // Ocultar mensagem após 5 segundos
        setTimeout(() => {
            successMessage.classList.remove('show');
        }, 5000);
    });
</script>

</body>
</html>
